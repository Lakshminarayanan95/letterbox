{
  "entities": {
    "Letter": {
      "title": "Letter",
      "description": "A Victorian love letter with text and media metadata.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The content of the letter." },
        "date": { "type": "string", "description": "The present timing when sealed." },
        "songTitle": { "type": "string", "description": "The title of the song." },
        "themeId": { "type": "string", "description": "The selected visual theme ID." },
        "media": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["image", "video", "audio"] },
              "url": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "createdAt"]
    }
  },
  "firestore": {
    "letters/{letterId}": {
      "schema": "Letter",
      "description": "Individual love letters identified by a unique ID."
    }
  }
}
